# ============================================================================
# Product Recommender — Environment Variables
# ============================================================================
# Copy this file to ".env" and fill in your own values.
# Vite only exposes variables prefixed with VITE_ to client-side code.
#
# The app supports TWO modes of operation:
#
#   1. LOCAL DEV  — set the VITE_AI_* variables below. The browser calls the
#                   AI API directly (fast iteration, no backend needed).
#
#   2. PRODUCTION (Vercel) — set the server-side AI_* variables in the Vercel
#                   dashboard. The client calls /api/recommend (a serverless
#                   function) which keeps the API key secret.
#
# If VITE_AI_API_KEY is set, the client uses it directly.
# If VITE_AI_API_KEY is NOT set, the client routes through /api/recommend.
# ============================================================================

# ---------------------------------------------------------------------------
# CLIENT-SIDE variables (local development only)
# ---------------------------------------------------------------------------
# These are bundled into the browser JS — never commit real keys here.
#
# OPTION A (default): OpenAI
# Get a key at https://platform.openai.com/api-keys
VITE_AI_API_KEY=sk-your-openai-key-here
VITE_AI_BASE_URL=https://api.openai.com/v1
VITE_AI_MODEL=gpt-4o-mini

# OPTION B: Any OpenAI-compatible provider (Groq, OpenRouter, LM Studio…)
# VITE_AI_BASE_URL=https://openrouter.ai/api/v1
# VITE_AI_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------------------------
# SERVER-SIDE variables (Vercel / production)
# ---------------------------------------------------------------------------
# Set these in the Vercel dashboard under Settings → Environment Variables.
# They are used by api/recommend.js and are NEVER sent to the browser.
#
# AI_API_KEY=sk-your-openai-key-here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# SECURITY NOTE
# ---------------------------------------------------------------------------
# In local dev the VITE_AI_API_KEY is bundled into client JS — this is fine
# for development but NOT safe for production.  When deployed to Vercel, omit
# all VITE_AI_* vars and set the server-side AI_* vars instead.  The app
# automatically detects this and routes requests through the secure
# /api/recommend serverless proxy.
